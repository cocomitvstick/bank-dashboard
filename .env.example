# Скопируйте этот файл в .env и заполните при необходимости
# Все параметры опциональны — приложение работает без них

# Хост и порт сервера
HOST=0.0.0.0
PORT=8000

# Уровень логирования: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Прокси (если ЦБ недоступен напрямую)
# HTTP_PROXY=http://proxy.example.com:3128
# HTTPS_PROXY=http://proxy.example.com:3128

# Таймаут запросов к ЦБ РФ (секунды)
CBR_TIMEOUT=15

# Директория для кэша данных (относительно backend/)
DATA_DIR=data
